# Supabase — copy to .env.local and fill in from your Supabase project settings
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key. Used by admin server actions to bypass RLS for image storage
# cleanup etc. NEVER expose to the browser / NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
